{
  "name": "compliance-saas",
  "version": "1.0.0",
  "description": "企业合规培训 SaaS 系统",
  "main": "main.js",
  "pages": [
    {
      "path": "pages/login/login",
      "style": {
        "navigationBarTitleText": "登录"
      }
    },
    {
      "path": "pages/home/home",
      "style": {
        "navigationBarTitleText": "首页",
        "enablePullDownRefresh": true
      }
    },
    {
      "path": "pages/course/list",
      "style": {
        "navigationBarTitleText": "课程中心"
      }
    },
    {
      "path": "pages/course/detail",
      "style": {
        "navigationBarTitleText": "课程详情"
      }
    },
    {
      "path": "pages/course/player",
      "style": {
        "navigationBarTitleText": "视频学习",
        "navigationStyle": "custom"
      }
    },
    {
      "path": "pages/profile/profile",
      "style": {
        "navigationBarTitleText": "个人中心"
      }
    },
    {
      "path": "pages/profile/certify",
      "style": {
        "navigationBarTitleText": "实名认证"
      }
    },
    {
      "path": "pages/report/report",
      "style": {
        "navigationBarTitleText": "学习报告"
      }
    }
  ],
  "globalStyle": {
    "navigationBarTextStyle": "black",
    "navigationBarTitleText": "合规培训",
    "navigationBarBackgroundColor": "#F8F8F8",
    "backgroundColor": "#F8F8F8"
  },
  "tabBar": {
    "color": "#7A7E83",
    "selectedColor": "#3cc51f",
    "borderStyle": "black",
    "backgroundColor": "#ffffff",
    "list": [
      {
        "pagePath": "pages/home/home",
        "iconPath": "static/images/home.png",
        "selectedIconPath": "static/images/home-active.png",
        "text": "首页"
      },
      {
        "pagePath": "pages/course/list",
        "iconPath": "static/images/course.png",
        "selectedIconPath": "static/images/course-active.png",
        "text": "课程"
      },
      {
        "pagePath": "pages/profile/profile",
        "iconPath": "static/images/profile.png",
        "selectedIconPath": "static/images/profile-active.png",
        "text": "我的"
      }
    ]
  },
  "uniIdRouter": {}
}
