{
  "name": "compliance-saas/backend",
  "description": "企业合规培训 SaaS 系统 - 后端",
  "type": "project",
  "require": {
    "php": ">=8.0",
    "topthink/framework": "^6.0",
    "topthink/think-orm": "^2.0",
    "topthink/think-view": "^1.0",
    "topthink/think-middleware": "^1.0",
    "topthink/think-captcha": "^3.0",
    "phpoffice/phpspreadsheet": "^1.28",
    "phpoffice/phpword": "^1.1",
    "dompdf/dompdf": "^2.0",
    "ext-openssl": "*",
    "ext-json": "*",
    "ext-zip": "*",
    "ext-gd": "*",
    "ext-mbstring": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^9.0"
  },
  "autoload": {
    "psr-4": {
      "app\\": "app/"
    },
    "files": []
  },
  "config": {
    "preferred-install": "dist",
    "sort-packages": true
  },
  "scripts": {
    "post-autoload-dump": [
      "@php think service:discover",
      "@php think vendor:publish"
    ]
  }
}
